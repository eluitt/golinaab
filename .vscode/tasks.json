{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Feature: Start",
      "type": "shell",
      "command": "scripts/steps.sh",
      "args": ["feature:start", "${input:featureSlug}"],
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "env": { "GN_DEV_BRANCH": "${input:devBranch}" },
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Feature: Commit",
      "type": "shell",
      "command": "scripts/steps.sh",
      "args": ["feature:commit", "--", "${input:commitMsg}"],
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Step: Tag (auto)",
      "type": "shell",
      "command": "scripts/steps.sh",
      "args": ["step:tag", "${input:stepSlug}"],
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Feature: Push",
      "type": "shell",
      "command": "scripts/steps.sh",
      "args": ["feature:push"],
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },

    {
      "label": "Git: Push wp-content → origin",
      "type": "shell",
      "command": "git push -u origin HEAD && git push origin --tags || true",
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },

    {
      "label": "Theme: Build (prod)",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder:wp}/themes/golitheme",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Theme: Dev (watch)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder:wp}/themes/golitheme",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },

    {
      "label": "ROOT: Submodule bump & commit",
      "type": "shell",
      "command": "git add wp-content && git commit -m \"chore(submodule): bump wp-content to ${input:stepSlug}\" || echo \"No changes\" && git push",
      "options": {
        "cwd": "${workspaceFolder:root}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "ROOT: Snapshot backup",
      "type": "shell",
      "command": "scripts/snapshot.sh",
      "options": {
        "cwd": "${workspaceFolder:root}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    { "id": "devBranch",   "type": "promptString", "description": "Develop branch name", "default": "golitheme" },
    { "id": "featureSlug", "type": "promptString", "description": "Feature slug (e.g. 01-header, 02-hero)", "default": "01-header" },
    { "id": "commitMsg",   "type": "promptString", "description": "Commit message", "default": "chore: commit" },
    { "id": "stepSlug",    "type": "promptString", "description": "Step slug for tag/submodule message", "default": "00-tooling" }
  ]
}
