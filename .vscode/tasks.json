{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Feature: Start",
      "type": "shell",
      "command": "scripts/steps.sh",
      "args": ["feature:start", "${input:featureName}"],
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Feature: Commit",
      "type": "shell",
      "command": "scripts/steps.sh",
      "args": ["feature:commit", "${input:commitMsg}"],
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Step: Tag (auto)",
      "type": "shell",
      "command": "scripts/steps.sh",
      "args": ["step:tag", "${input:stepSlug}"],
      "options": {
        "cwd": "${workspaceFolder:wp}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Snapshot backup (follow golitheme)",
      "type": "shell",
      "command": "scripts/snapshot.sh",
      "options": {
        "cwd": "${workspaceFolder:root}",
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-lc"]
        }
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    { "id": "featureName", "type": "promptString", "description": "Feature slug", "default": "header" },
    { "id": "commitMsg",   "type": "promptString", "description": "Commit message", "default": "feat(theme): ..." },
    { "id": "stepSlug",    "type": "promptString", "description": "Step slug", "default": "header" }
  ]
}
