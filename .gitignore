# --- WordPress core (do not track)
#/ index.php + core php in root
/index.php
/wp-*.php
/xmlrpc.php
/readme.html
/license.txt
/wp-admin/
wp-admin/
/wp-includes/
wp-includes/

# --- Root-level configs & secrets (do not track)
/wp-config.php
/wp-config-local.php
/.env
/.env.*
/.htaccess

# --- Editor junk & archives
*.log
.DS_Store
Thumbs.db
*.zip
*.tar
*.tar.gz
*.7z
.idea/
.vscode/

# --- If wp-content is a GIT SUBMODULE, you don't need inner rules.
# Only track the submodule pointer; contents are managed in that repo.
# (No need to ignore /wp-content/* paths here.)
